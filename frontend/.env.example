# Backend API Configuration
#
# For development: The Vite dev server proxies requests to this URL
# For production: The frontend makes direct API calls to this URL
#
# Examples:
#   Local development:     VITE_API_URL=http://localhost:8000
#   Remote backend:        VITE_API_URL=http://192.168.1.100:8000
#   Production server:     VITE_API_URL=https://api.example.com

VITE_API_URL=http://localhost:8000

# Phase 14 — frontend reads CSRF token from cookie; no env var needed
# Backend FRONTEND_URL must be set to the URL serving this frontend
# (see app/core/config.py AuthSettings.FRONTEND_URL — CORS allowlist)
