# Environment Configuration
# Copy this file to .env and update with your values

# ============================================
# Environment Settings
# ============================================
# Options: development, testing, production
ENVIRONMENT=development

# Enable development mode (optional)
DEV=true

# ============================================
# Database Configuration
# ============================================
# Database connection URL
DB_URL=sqlite:///records.db

# PostgreSQL example:
# DB_URL=postgresql://user:pass@localhost/dbname

# MySQL example:
# DB_URL=mysql://user:pass@localhost/dbname

# Echo SQL queries (set true for debugging)
DB_ECHO=false

# ============================================
# WhisperX ML Configuration
# ============================================
# Required for model downloads from HuggingFace
HF_TOKEN=<your-huggingface-token>

# Whisper model size
# Options: tiny, tiny.en, base, base.en, small, small.en, medium, medium.en,
#          large, large-v1, large-v2, large-v3, large-v3-turbo,
#          distil-large-v2, distil-large-v3, distil-medium.en, distil-small.en
WHISPER_MODEL=tiny

# Default transcription language code (ISO 639-1)
DEFAULT_LANG=en

# Device to use for computation
# Options: cuda, cpu (auto-detected if not set)
DEVICE=cuda

# Compute type for model inference
# Options: float16, float32, int8
# CRITICAL: MUST be int8 when DEVICE=cpu
COMPUTE_TYPE=float16

# ============================================
# Language-Specific Model Overrides (Optional)
# ============================================
# Fine-tuned models for specific languages (CTranslate2 format).
# When a language is selected that has an override here, the fine-tuned
# model is used automatically instead of the default Whisper model.
#
# Format: JSON object mapping ISO 639-1 codes to local paths or HuggingFace repo IDs
# Example for Latvian (6x better WER than stock Whisper):
#   1. Download: hf download AiLab-IMCS-UL/whisper-large-v3-lv-late-cv19 --include "ct2-int8/*"
#   2. Set the path below to the downloaded ct2-int8 folder
#
# LANGUAGE_MODEL_OVERRIDES={"lv": "/path/to/ct2-int8"}

# ============================================
# Logging Configuration
# ============================================
# Logging level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format
# Options: text, json
LOG_FORMAT=text

# Filter specific warnings
FILTER_WARNING=true

# ============================================
# === Auth (v1.2) ===
# ============================================
# v1.2 introduces multi-user auth + API keys + Stripe-ready billing.
# See docs/migration-v1.2.md for the operator runbook.
#
# IMPORTANT: every variable in this block is read by AuthSettings, which
# uses env_prefix="AUTH__" with case_sensitive=True (app/core/config.py:145-151).
# The names below are the WIRE FORMAT pydantic-settings reads; do NOT strip
# the AUTH__ prefix in your real .env or AuthSettings will silently fall
# back to its in-code defaults (dev) or raise ValueError at boot (production).

# --- Feature flag (master gate) ---
# AUTH__V2_ENABLED=true mounts the v1.2 auth/keys/account/billing/ws_ticket routers
# (app/main.py:247-252). Production REFUSES to boot with this set to false
# (app/main.py:257). Dev/test default is false; smoke verify in
# docs/migration-v1.2.md Section 8 is meaningless without this set true.
AUTH__V2_ENABLED=true

# --- Auth secrets ---
# Generate each with: openssl rand -hex 32
# CRITICAL: refuses to boot in production if either remains the dev default.
AUTH__JWT_SECRET=<change-me-in-production>
AUTH__CSRF_SECRET=<change-me-in-production>

# --- Cookie & CORS ---
# AUTH__COOKIE_SECURE=true forces HTTPS-only cookies (set true in production).
AUTH__COOKIE_SECURE=false
# AUTH__COOKIE_DOMAIN scopes the session cookie. Empty = host-only (recommended for dev).
AUTH__COOKIE_DOMAIN=
# AUTH__FRONTEND_URL is the allowed CORS origin and the auth redirect target.
AUTH__FRONTEND_URL=http://localhost:5173
# AUTH__TRUST_CF_HEADER=true reads CF-Connecting-IP behind Cloudflare (rate-limit grouping).
AUTH__TRUST_CF_HEADER=false

# --- Rate limit ---
# NOTE: rate limits are currently HARDCODED in code, not env-configurable.
#   - Register: 3/hour      (app/api/auth_routes.py:123 @limiter.limit("3/hour"))
#   - Login:    10/hour     (app/api/auth_routes.py:160 @limiter.limit("10/hour"))
#   - Free tier transcribe: 5/hour (app/services/free_tier_gate.py:58-65 FREE_POLICY.max_per_hour)
# Per /24 IPv4 subnet (or /64 IPv6). Anti-spam (ANTI-01/02).
# Wiring these to env vars is tracked for v1.3; until then editing them here
# has no effect — change the decorators / FREE_POLICY constants directly.

# --- Argon2 ---
# OWASP-recommended params (m=19456 KiB, t=2, p=1). p99 ~35ms on x86_64.
# Field names mirror app/core/config.py:158-160 (T_COST/M_COST, NOT TIME_COST/MEMORY_KIB).
AUTH__ARGON2_T_COST=2
AUTH__ARGON2_M_COST=19456
AUTH__ARGON2_PARALLELISM=1

# --- hCaptcha ---
# Activate only if abuse observed during v1.2 soak (Phase 18 stretch).
AUTH__HCAPTCHA_ENABLED=false
AUTH__HCAPTCHA_SITE_KEY=
AUTH__HCAPTCHA_SECRET=

# ============================================
# Notes
# ============================================
# - Required fields: HF_TOKEN (for model downloads)
# - When using CPU (DEVICE=cpu), you MUST set COMPUTE_TYPE=int8
# - Environment variables can use nested format with __ separator:
#   - database__DB_URL=sqlite:///records.db
#   - whisper__WHISPER_MODEL=tiny
#   - logging__LOG_LEVEL=DEBUG
# - Language model overrides are applied server-side: when a request
#   specifies a language that has an override, the fine-tuned model
#   is loaded instead of the default Whisper model. The API model
#   parameter is ignored for that language.
